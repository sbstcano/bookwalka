# Copy this file to .env and adjust values as needed.

# Translation provider: mock, gemini, openai, deepseek
MANGA_TRANSLATION_PROVIDER=mock
MANGA_TRANSLATION_MODEL=mock-model

# API keys (required for gemini/openai/deepseek when using official endpoints)
MANGA_GEMINI_API_KEY=your_gemini_api_key
MANGA_OPENAI_API_KEY=your_openai_api_key
MANGA_DEEPSEEK_API_KEY=your_deepseek_api_key

# DeepSeek API Base (default: https://api.deepseek.com/v1)
# MANGA_DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Optional API Key to secure this FastAPI server (auth is bypassed if left empty)
# MANGA_BACKEND_API_KEY=your_secure_secret_key

# OpenAI-compatible API base (default: official OpenAI)
# MANGA_OPENAI_API_BASE=https://api.openai.com/v1

# Local LLM example (Ollama / LM Studio — no API key needed)
# MANGA_TRANSLATION_PROVIDER=openai
# MANGA_OPENAI_API_BASE=http://127.0.0.1:11434/v1
# MANGA_TRANSLATION_MODEL=your-local-model-name

# OCR device: cpu or cuda
MANGA_DEVICE=cpu